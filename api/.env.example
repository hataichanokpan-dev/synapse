# Synapse API Configuration
# Copy to .env and customize

# Server
SYNAPSE_API_PORT=8000
DEBUG=false

# Authentication (optional in dev mode)
SYNAPSE_API_KEY=synapse-dev-key

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database connections (same as Synapse)
FALKORDB_URI=redis://localhost:6379
QDRANT_URL=http://localhost:6333
SQLITE_PATH=~/.synapse/synapse.db

# LLM (for Oracle tools)
ANTHROPIC_API_KEY=
